# Kopiere diese Datei nach `.env.local` (gitignored) und trage echte Werte ein.
# In Produktion: Vercel → Project → Settings → Environment Variables.

# --- KI-Coach (Phase B) -----------------------------------------------------
# Server-seitig — wird nur in app/api/coach/route.ts gelesen, nie im Browser.
# Ohne diesen Schlüssel zeigt der Coach „noch nicht eingerichtet"; die App läuft normal.
ANTHROPIC_API_KEY=

# --- Cloud-Sync (Phase C) ---------------------------------------------------
# Öffentlicher Anon-Key — Sicherheit kommt aus Row-Level-Security, nicht aus Geheimhaltung.
# Nach dem Setzen: supabase/migrations/0001_app_state.sql ausführen.
# Ohne diese Werte bleiben alle Daten lokal (kein Login, kein Sync).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
